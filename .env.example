# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-pyq-analyzer-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db/pyq_analyzer.sqlite3

# Google Gemini API Keys (comma-separated for automatic rotation)
# Get keys from https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=your-gemini-api-key-1,your-gemini-api-key-2,your-gemini-api-key-3
GEMINI_MODEL=gemini-2.0-flash

# GitHub Models API (GPT-4o fallback when Gemini fails)
# Get token from https://github.com/settings/tokens (needs Models API access)
GITHUB_MODELS_TOKEN=your-github-token-here
GITHUB_MODELS_MODEL=gpt-4o

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Media Files
MEDIA_ROOT=media
MEDIA_URL=/media/

# Email (Console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
